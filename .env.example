# Postgres. Neon or Supabase both work; use the pooled connection string on Vercel.
DATABASE_URL=

# KYC/data aggregator credentials.
# The source layer is deliberately provider-agnostic — Perfios/Karza, Signzy,
# SurePass, IDfy and AuthBridge all cover overlapping subsets of these portals,
# so the adapter interface stays stable if the provider changes.
AGGREGATOR_API_KEY=
AGGREGATOR_BASE_URL=
